# Normalize all text files to LF in the repo AND on checkout, so Windows
# working copies stop showing generated .dart / platform files as "modified"
# (the CRLF churn that keeps reappearing after build_runner / pub get).
* text=auto eol=lf

# Source / config — always LF.
*.dart   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.gradle text eol=lf
*.kts    text eol=lf
*.swift  text eol=lf
*.cc     text eol=lf
*.cpp    text eol=lf
*.h      text eol=lf
*.cmake  text eol=lf
*.xml    text eol=lf
*.svg    text eol=lf
*.properties text eol=lf

# Windows-specific scripts keep CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
*.jar  binary
*.keystore binary
*.p12  binary
*.lottie binary
